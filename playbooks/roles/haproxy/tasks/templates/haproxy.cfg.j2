frontend kubernetes-apiserver
    bind *:6443
    mode tcp
    option tcplog
    default_backend kubernetes-masters

backend kubernetes-masters
    mode tcp
    balance roundrobin
    option tcp-check
    server master1 192.168.85.101:6443 check fall 3 rise 2
    server master2 192.168.85.102:6443 check fall 3 rise 2
    server master3 192.168.85.103:6443 check fall 3 rise 2

